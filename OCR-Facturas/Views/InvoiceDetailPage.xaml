<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OCR_Facturas.ViewModels"
             xmlns:models="clr-namespace:OCR_Facturas.Models"
             xmlns:components="clr-namespace:OCR_Facturas.Views.Components"
             x:Class="OCR_Facturas.Views.InvoiceDetailPage"
             x:DataType="vm:InvoiceDetailViewModel"
             BackgroundColor="#121212">

    <Grid RowDefinitions="Auto,*">

        <Border Grid.Row="0" BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="20" Margin="0,0,0,10">
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding Invoice.MerchantName}" TextColor="#FACC15" FontSize="22" FontAttributes="Bold" />
                <Label Text="{Binding Invoice.IssueDate, StringFormat='Fecha: {0:dd/MM/yyyy}'}" TextColor="#AAAAAA" FontSize="14" />

                <BoxView HeightRequest="1" Color="#333333" Margin="0,10" />

                <Grid ColumnDefinitions="*,*">
                   

                    <Label Grid.Column="1" Text="TOTAL:" TextColor="#FACC15" FontAttributes="Bold" FontSize="18" />
                    <Label Grid.Column="1" Text="{Binding Invoice.TotalAmount, StringFormat='{}{0:C2}'}" TextColor="#FACC15" HorizontalOptions="End" FontAttributes="Bold" FontSize="18" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Invoice.Items}" Margin="15,15,15,15">

            <CollectionView.Header>
                <Label Text="Productos" TextColor="White" FontSize="18" FontAttributes="Bold" Margin="10,10,10,15"/>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:InvoiceItemDto">
                    <components:InvoiceDetailItemCard />
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="No se detectaron productos en esta factura."
               TextColor="#888888"
               HorizontalOptions="Center"
               Margin="0,30,0,0"/>
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>