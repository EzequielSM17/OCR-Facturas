<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:OCR_Facturas.Models"
             xmlns:vm="clr-namespace:OCR_Facturas.ViewModels"
             x:Class="OCR_Facturas.Views.Components.InvoiceHistoryCard"
             x:DataType="models:InvoiceDto">

    <Border BackgroundColor="#1E1E1E"
            Stroke="#333333"
            StrokeThickness="1"
            Margin="12,12,12,12"
            Padding="15">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12" />
        </Border.StrokeShape>

        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=VerDetalleCommand}"
                CommandParameter="{Binding .}" />
        </Border.GestureRecognizers>

        <Grid ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              RowSpacing="10">

            <Label Grid.Row="0"
                   Grid.Column="0"
                   Text="{Binding MerchantName}"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="16"
                   LineBreakMode="TailTruncation"
                   VerticalOptions="Center" />

            <Label Grid.Row="1"
                   Grid.Column="0"
                   Text="{Binding IssueDate, StringFormat='{}{0:dd MMM yyyy}'}"
                   TextColor="#888888"
                   FontSize="13"
                   VerticalOptions="Center" />

            <Label Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding TotalAmount, StringFormat='{}{0:C2}'}"
                   TextColor="#FACC15"
                   FontAttributes="Bold"
                   FontSize="16"
                   HorizontalOptions="End"
                   VerticalOptions="Center" />

            <Button Grid.Row="1"
                    Grid.Column="1"
                    Text="Borrar"
                    TextColor="#EF4444"
                    BackgroundColor="Transparent"
                    FontAttributes="Bold"
                    FontSize="12"
                    BorderColor="#EF4444"
                    BorderWidth="1"
                    CornerRadius="8"
                    Padding="4,0,4,0"
                    HeightRequest="30"
                    HorizontalOptions="End"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=EliminarFacturaCommand}"
                    CommandParameter="{Binding .}" />
        </Grid>
    </Border>
</ContentView>