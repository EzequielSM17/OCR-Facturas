<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:OCR_Facturas.Models"
             x:Class="OCR_Facturas.Views.Components.InvoiceItemCard"
             x:DataType="models:InvoiceDto">

    
    <Border Stroke="LightGray" 
        StrokeThickness="1" 
        Padding="15" 
        Margin="10,10,10,10">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,2" Opacity="0.15" Radius="4" />
        </Border.Shadow>

        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
            <Label Grid.Row="0" Grid.Column="0" Text="{Binding MerchantName}" FontAttributes="Bold" FontSize="16" />
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{0:C}'}" 
        FontAttributes="Bold" FontSize="16" TextColor="Green" />

            <Label Grid.Row="1" Grid.Column="0" Text="{Binding IssueDate, StringFormat='{0:dd MMM yyyy}'}" 
        FontSize="12" TextColor="Gray" Margin="0,5,0,0"/>
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Items.Count, StringFormat='{0} items'}" 
        FontSize="12" TextColor="Gray" Margin="0,5,0,0" HorizontalOptions="End"/>
        </Grid>
    </Border>
</ContentView>