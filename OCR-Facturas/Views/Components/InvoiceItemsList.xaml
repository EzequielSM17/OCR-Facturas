<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OCR_Facturas.ViewModels"
             xmlns:components="clr-namespace:OCR_Facturas.Views.Components"
             xmlns:models="clr-namespace:OCR_Facturas.Models"
             x:Class="OCR_Facturas.Views.Components.InvoiceItemsList"
             x:DataType="vm:MainViewModel">

    <VerticalStackLayout Spacing="12">
        <Label Text="Productos Detectados:"
               TextColor="#AAAAAA"
               FontAttributes="Bold"
               FontSize="14"
               Margin="0,0,0,-5"/>

        <VerticalStackLayout BindableLayout.ItemsSource="{Binding ItemsDisplay}" Spacing="12">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="models:InvoiceItemDisplayDto">
                    <components:InvoiceItemCard />
                </DataTemplate>
            </BindableLayout.ItemTemplate>

            <BindableLayout.EmptyViewTemplate>
                <DataTemplate>
                    <Label Text="No se detectaron productos en la tabla."
                           TextColor="#666666"
                           FontAttributes="Italic"
                           HorizontalOptions="Center"
                           Margin="0,10,0,10"/>
                </DataTemplate>
            </BindableLayout.EmptyViewTemplate>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>