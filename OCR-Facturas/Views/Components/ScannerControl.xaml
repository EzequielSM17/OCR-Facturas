<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OCR_Facturas.ViewModels"
             xmlns:models="clr-namespace:OCR_Facturas.Models"
             x:Class="OCR_Facturas.Views.Components.ScannerControl"
             x:DataType="vm:MainViewModel"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Border Stroke="#333333"
                    StrokeThickness="2"
                    BackgroundColor="#1E1E1E"
                    Padding="0"
                    MinimumHeightRequest="350">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Grid>
                    <Image Source="{Binding PreviewImage}" Aspect="AspectFit" Margin="5"/>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="10"
                                         IsVisible="{Binding PreviewImage, Converter={StaticResource IsNullConverter}}">
                        <Label Text="📷" FontSize="40" HorizontalOptions="Center"/>
                        <Label Text="Ninguna imagen seleccionada" TextColor="#888888" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Button Grid.Column="0" Text="📸 Cámara" Command="{Binding TakePhotoCommand}"
                        BackgroundColor="#333333" TextColor="White" CornerRadius="10" HeightRequest="45" />
                <Button Grid.Column="1" Text="🖼️ Galería" Command="{Binding PickPhotoCommand}"
                        BackgroundColor="#333333" TextColor="White" CornerRadius="10" HeightRequest="45" />
            </Grid>

            <Button Text="✨ Extraer Datos"
                    Command="{Binding ExtractDataCommand}"
                    BackgroundColor="#FACC15"
                    TextColor="#121212"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="10"
                    HeightRequest="55"
                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertedBoolConverter}}"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" IsVisible="{Binding IsProcessing}">
                <ActivityIndicator IsRunning="True" Color="#FACC15"/>
                <Label Text="{Binding StatusMessage}" VerticalOptions="Center" TextColor="#FACC15" FontAttributes="Bold"/>
            </HorizontalStackLayout>

            <Border IsVisible="{Binding MostrarResultados}"
                    BackgroundColor="#1E1E1E"
                    Stroke="#FACC15"
                    StrokeThickness="1"
                    Padding="20"
                    Margin="0,10,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">

                    <Label Text="📋 Resumen de la Factura"
                           TextColor="#FACC15"
                           FontAttributes="Bold"
                           FontSize="18"
                           HorizontalOptions="Center"/>

                    <BoxView HeightRequest="1" Color="#333333" Margin="0,0,0,5"/>

                    <!-- RESUMEN OCR -->
                    <Border BackgroundColor="#181818"
                            Stroke="#333333"
                            StrokeThickness="1"
                            Padding="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="Confianza media OCR:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding OcrAverageConfidenceText}" TextColor="{Binding OcrAverageConfidenceColor}" FontAttributes="Bold"/>

                            <Label Grid.Row="1" Grid.Column="0" Text="Confianza documento:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding OcrDocumentConfidenceText}" TextColor="{Binding OcrDocumentConfidenceColor}" FontAttributes="Bold"/>

                            <Label Grid.Row="2" Grid.Column="0" Text="Proveedor:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding MerchantNameConfidenceText}" TextColor="{Binding MerchantNameConfidenceColor}" FontAttributes="Bold"/>

                            <Label Grid.Row="3" Grid.Column="0" Text="Fecha:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding IssueDateConfidenceText}" TextColor="{Binding IssueDateConfidenceColor}" FontAttributes="Bold"/>

                            <Label Grid.Row="4" Grid.Column="0" Text="Total:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding TotalAmountConfidenceText}" TextColor="{Binding TotalAmountConfidenceColor}" FontAttributes="Bold"/>

                            <Label Grid.Row="5" Grid.Column="0" Text="Productos:" TextColor="#AAAAAA" FontAttributes="Bold"/>
                            <Label Grid.Row="5" Grid.Column="1" Text="{Binding ItemsConfidenceText}" TextColor="{Binding ItemsConfidenceColor}" FontAttributes="Bold"/>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0" Text="Proveedor:" TextColor="#888888" FontAttributes="Bold" Margin="0,0,15,0"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding FacturaActual.MerchantName}" TextColor="White" FontAttributes="Bold" HorizontalOptions="End" LineBreakMode="TailTruncation"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="Fecha:" TextColor="#888888" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding FacturaActual.IssueDate, StringFormat='{}{0:dd/MM/yyyy}'}" TextColor="White" HorizontalOptions="End"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="TOTAL:" TextColor="#FACC15" FontAttributes="Bold" FontSize="16"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding FacturaActual.TotalAmount, StringFormat='{}{0:C2}'}" TextColor="#FACC15" FontAttributes="Bold" FontSize="16" HorizontalOptions="End"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#333333" Margin="0,5,0,0"/>

                    <Label Text="Productos Detectados:"
                           TextColor="#AAAAAA"
                           FontAttributes="Bold"
                           FontSize="14"
                           Margin="0,0,0,-5"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ItemsDisplay}" Spacing="12">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:InvoiceItemDisplayDto">
                                <Border BackgroundColor="#181818" Stroke="#333333" StrokeThickness="1" Padding="12">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>

                                    <VerticalStackLayout Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Description}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"/>

                                            <Label Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding AverageConfidenceText}"
                                                   TextColor="{Binding ConfidenceColor}"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End"/>

                                            <Label Grid.Row="1" Grid.Column="0"
                                                   TextColor="#888888"
                                                   FontSize="12">
                                                <Label.Text>
                                                    <MultiBinding StringFormat="{}Cant: {0} | Und: {1:C2}">
                                                        <Binding Path="Quantity" />
                                                        <Binding Path="UnitPrice" />
                                                    </MultiBinding>
                                                </Label.Text>
                                            </Label>

                                            <Label Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding TotalPrice, StringFormat='{}{0:C2}'}"
                                                   TextColor="White"
                                                   HorizontalOptions="End"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                                            <Label Grid.Row="0" Grid.Column="0" Text="Descripción:" TextColor="#777777" FontSize="12"/>
                                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding DescriptionConfidenceText}" TextColor="#AAAAAA" FontSize="12"/>

                                            <Label Grid.Row="1" Grid.Column="0" Text="Cantidad:" TextColor="#777777" FontSize="12"/>
                                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding QuantityConfidenceText}" TextColor="#AAAAAA" FontSize="12"/>

                                            <Label Grid.Row="2" Grid.Column="0" Text="Precio unidad:" TextColor="#777777" FontSize="12"/>
                                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding UnitPriceConfidenceText}" TextColor="#AAAAAA" FontSize="12"/>

                                            <Label Grid.Row="3" Grid.Column="0" Text="Total línea:" TextColor="#777777" FontSize="12"/>
                                            <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalPriceConfidenceText}" TextColor="#AAAAAA" FontSize="12"/>

                                            <Label Grid.Row="4" Grid.Column="0" Text="Impuesto:" TextColor="#777777" FontSize="12"/>
                                            <Label Grid.Row="4" Grid.Column="1" Text="{Binding TaxConfidenceText}" TextColor="#AAAAAA" FontSize="12"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                        <BindableLayout.EmptyViewTemplate>
                            <DataTemplate>
                                <Label Text="No se detectaron productos en la tabla."
                                       TextColor="#666666"
                                       FontAttributes="Italic"
                                       HorizontalOptions="Center"
                                       Margin="0,10,0,10"/>
                            </DataTemplate>
                        </BindableLayout.EmptyViewTemplate>
                    </VerticalStackLayout>

                    <Button Text="💾 Confirmar y Guardar"
                            Command="{Binding GuardarFacturaCommand}"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="55"
                            Margin="0,15,0,0"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>